{
  "name": "auth-a2a-agent-network",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Two-agent prior authorization system over the Google A2A protocol",
  "scripts": {
    "payer": "bun run src/agents/payer/server.ts",
    "provider": "bun run src/agents/provider/server.ts",
    "scenario:1": "bun run demo/scenarios/scenario-1-clean-approval.ts",
    "scenario:2": "bun run demo/scenarios/scenario-2-denial-appeal.ts",
    "scenario:3": "bun run demo/scenarios/scenario-3-human-review.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@anthropic-ai/sdk": "^0.65.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.4.0",
    "express": "^4.21.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
