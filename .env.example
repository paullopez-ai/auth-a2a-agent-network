# --- Agent ports ---
PROVIDER_PORT=4001
PAYER_PORT=4002

# Agent discovery URLs (Provider discovers Payer at startup).
# In AWS these are replaced by ECS Service Connect / ALB DNS names.
PROVIDER_URL=http://localhost:4001
PAYER_URL=http://localhost:4002

# --- LLM ---
# MOCK_LLM=true uses deterministic responses keyed to scenario ID (no API key
# needed). Required for the Demo track and for ALL tests. Never call real Claude
# in the test suite.
MOCK_LLM=true

# Required only when MOCK_LLM=false (live LLM track).
ANTHROPIC_API_KEY=

# Route inference through AWS Bedrock instead of the direct Anthropic API.
USE_BEDROCK=false
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Optional MCP knowledge layer ---
# If clinical-rules-mcp-server is running, CriteriaLookupNode calls it; otherwise
# it falls back to embedded synthetic criteria. Never a hard dependency.
MCP_SERVER_URL=
